{
  "name": "my-smart-coding-plugin",
  "displayName": "my-smart-coding-plugin",
  "description": "Our firest vscode plugin for HITers' First-Year Annual Project!!!Success!!!",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.108.1"
  },  
  "main": "./extension.js",
  "categories": [
    "Other"
  ],
  "activationEvents": [
   
],
"contributes": {
    "commands": [
      {
        "command": "my-smart-coding-plugin.insertLog",
        "title": "AI: 插入 Console Log"
      },
      {
        "command": "my-smart-coding-plugin.explainCode",
        "title": "AI: 解释这段代码"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "my-smart-coding-plugin.insertLog",
          "when": "editorHasSelection",
          "group": "navigation"
        },
        {
          "command": "my-smart-coding-plugin.explainCode",
          "when": "editorHasSelection",
          "group": "navigation"
        }
      ]
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.3.1"
  }
}
